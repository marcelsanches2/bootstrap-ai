#!/usr/bin/env python3
"""Non-destructive project lifecycle kit manager."""
from __future__ import annotations
import argparse, datetime as dt, filecmp, hashlib, json, os, shutil, subprocess, sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
KITS = ROOT / 'presets'
LOCKFILE = '.bootstrap-ai.lock'

REQUIRED_COMMON = [
    'CLAUDE.md',
    '.claude/commands/plan.md',
    '.claude/commands/jarvis-plan-revisor.md',
    '.claude/commands/jarvis-test-flow.md',
    '.claude/commands/refactor.md',
    '.claude/commands/ship.md',
    '.claude/commands/product_roles/localizar-plano.md',
    '.claude/commands/product_roles/carregar-referencias.md',
    '.claude/commands/product_roles/consolidar-parecer.md',
    '.claude/commands/product_roles/gerar-relatorio.md',
    'docs/ai/ARCHITECTURE.md',
    'docs/ai/CODING_STANDARDS.md',
    'docs/ai/FEATURE_GUIDE.md',
    'docs/ai/TESTING_GUIDE.md',
]

def die(msg: str, code: int = 1) -> None:
    print(f'erro: {msg}', file=sys.stderr)
    raise SystemExit(code)

def sha(path: Path) -> str:
    h = hashlib.sha256(); h.update(path.read_bytes()); return h.hexdigest()

def kit_path(name: str) -> Path:
    p = KITS / name
    if not p.is_dir():
        die(f'kit não encontrado: {name}')
    return p

def list_kits() -> list[str]:
    return sorted(p.name for p in KITS.iterdir() if p.is_dir()) if KITS.exists() else []


def read_text_if_exists(path: Path) -> str:
    try:
        return path.read_text(encoding='utf-8', errors='ignore') if path.exists() and path.is_file() else ''
    except Exception:
        return ''

def package_json(target: Path) -> dict:
    try:
        return json.loads((target/'package.json').read_text(encoding='utf-8'))
    except Exception:
        return {}


def pubspec_deps(target: Path) -> set[str]:
    txt=read_text_if_exists(target/'pubspec.yaml')
    deps=set()
    in_dep=False
    for raw in txt.splitlines():
        if not raw.strip() or raw.lstrip().startswith('#'):
            continue
        if raw.startswith(('dependencies:', 'dev_dependencies:')):
            in_dep=True; continue
        if raw and not raw.startswith(' ') and not raw.startswith('\t'):
            in_dep=False
        if in_dep:
            line=raw.strip()
            if ':' in line:
                name=line.split(':',1)[0].strip()
                if name and name not in {'sdk','flutter'}:
                    deps.add(name)
    return deps

def python_deps(target: Path) -> set[str]:
    blob='\n'.join(read_text_if_exists(target/f).lower() for f in ['pyproject.toml','requirements.txt','setup.py'])
    known={'fastapi','django','flask','sqlalchemy','alembic','pydantic','pytest','ruff','mypy','httpx','requests','celery','redis','psycopg','asyncpg','uvicorn','gunicorn'}
    return {k for k in known if k in blob}

def node_deps(target: Path) -> set[str]:
    pkg=package_json(target)
    deps={}
    for key in ['dependencies','devDependencies','peerDependencies','optionalDependencies']:
        deps.update(pkg.get(key) or {})
    scripts=pkg.get('scripts') or {}
    names=set(deps.keys())
    # include script tools only when they imply project workflow
    script_blob=' '.join(list(scripts.keys()) + list(scripts.values())).lower()
    for k in ['tsc','vite','next','jest','vitest','playwright','cypress','eslint','prettier']:
        if k in script_blob: names.add(k)
    return names

def gem_deps(target: Path) -> set[str]:
    gem=read_text_if_exists(target/'Gemfile').lower()
    known={'rails','pg','puma','sidekiq','redis','rspec','rubocop','devise','graphql','faraday'}
    return {k for k in known if k in gem}

def project_tech(target: Path) -> tuple[set[str], list[str]]:
    """Detecta tecnologias e bibliotecas estruturais para escolher/criar kit.

    Retorna um conjunto único por compatibilidade histórica, mas separa a decisão:
    CORE_TECH define stack; STRUCTURAL_LIBS define bibliotecas que mudam arquitetura.
    """
    tech=set(); signals=[]
    def add(name, sig):
        tech.add(name); signals.append(sig)

    if (target/'pubspec.yaml').exists():
        add('dart', 'pubspec.yaml')
        txt=read_text_if_exists(target/'pubspec.yaml').lower()
        if 'flutter:' in txt:
            add('flutter', 'flutter: in pubspec.yaml')
        deps=pubspec_deps(target)
        flutter_libs={
            'dio':'dio', 'http':'http', 'graphql_flutter':'graphql_flutter',
            'riverpod':'riverpod', 'flutter_riverpod':'flutter_riverpod', 'hooks_riverpod':'hooks_riverpod',
            'provider':'provider', 'flutter_bloc':'flutter_bloc', 'bloc':'bloc', 'get':'getx', 'mobx':'mobx',
            'go_router':'go_router', 'auto_route':'auto_route',
            'freezed':'freezed', 'json_serializable':'json_serializable', 'build_runner':'build_runner',
            'drift':'drift', 'sqflite':'sqflite', 'isar':'isar', 'hive':'hive',
            'firebase_core':'firebase', 'firebase_auth':'firebase_auth', 'cloud_firestore':'cloud_firestore',
            'flutter_test':'flutter_test', 'mocktail':'mocktail', 'mockito':'mockito', 'integration_test':'integration_test',
        }
        for dep, tag in flutter_libs.items():
            if dep in deps: add(tag, f'{dep} in pubspec dependencies')

    if any((target/f).exists() for f in ['pyproject.toml','requirements.txt','setup.py']):
        add('python', 'python packaging file')
        deps=python_deps(target)
        for name in sorted(deps):
            add(name, f'{name} detected')

    pkg=package_json(target)
    if pkg:
        add('node', 'package.json')
        deps=node_deps(target)
        node_libs={
            'typescript':'typescript', 'tsc':'typescript', 'react':'react', '@vitejs/plugin-react':'react',
            'next':'next', 'vite':'vite', 'tailwindcss':'tailwind',
            'express':'express', 'fastify':'fastify', '@nestjs/core':'nestjs',
            'prisma':'prisma', '@prisma/client':'prisma', 'drizzle-orm':'drizzle',
            'axios':'axios', '@tanstack/react-query':'tanstack-query', 'react-query':'react-query',
            'zustand':'zustand', 'redux':'redux', '@reduxjs/toolkit':'redux-toolkit',
            'react-router-dom':'react-router', 'zod':'zod', 'react-hook-form':'react-hook-form',
            'jest':'jest', 'vitest':'vitest', 'playwright':'playwright', 'cypress':'cypress',
            'eslint':'eslint', 'prettier':'prettier'
        }
        for dep, tag in node_libs.items():
            if dep in deps: add(tag, f'{dep} in package metadata')

    if (target/'go.mod').exists():
        add('go', 'go.mod')
        gomod=read_text_if_exists(target/'go.mod').lower()
        for needle, tag in [('gin-gonic/gin','gin'),('go-chi/chi','chi'),('gofiber/fiber','fiber'),('jackc/pgx','pgx'),('gorm.io/gorm','gorm'),('pressly/goose','goose'),('sqlc-dev/sqlc','sqlc')]:
            if needle in gomod: add(tag, f'{tag} in go.mod')

    if (target/'Gemfile').exists() or list(target.glob('*.gemspec')):
        add('ruby', 'Gemfile/gemspec')
        deps=gem_deps(target)
        if 'rails' in deps or (target/'config/application.rb').exists(): add('rails', 'Rails detected')
        for name in sorted(deps - {'rails'}): add(name, f'{name} in Gemfile')

    if any((target/f).exists() for f in ['Cargo.toml']): add('rust', 'Cargo.toml')
    if any(target.glob('*.csproj')) or any(target.glob('*.sln')): add('dotnet', '.NET project file')
    if any((target/f).exists() for f in ['pom.xml','build.gradle','build.gradle.kts']): add('java', 'JVM build file')

    blob='\n'.join(read_text_if_exists(target/f).lower() for f in ['docker-compose.yml','docker-compose.yaml','.env.example','README.md','package.json','pyproject.toml','requirements.txt','Gemfile'])
    if 'postgres' in blob or 'psycopg' in blob or '"pg"' in blob or "'pg'" in blob or 'gem "pg"' in blob or "gem 'pg'" in blob: add('postgres', 'postgres signal')
    if 'sqlite' in blob or list(target.glob('*.sqlite')) or list(target.glob('*.db')): add('sqlite', 'sqlite signal')
    if 'redis' in blob: add('redis', 'redis signal')

    return tech, signals

KIT_COVERAGE = {
    'flutter-app': {'dart','flutter','dio','http','riverpod','flutter_riverpod','hooks_riverpod','go_router','freezed','json_serializable','build_runner','mocktail','mockito','integration_test'},
    'python-backend': {'python','fastapi','sqlalchemy','alembic','postgres','sqlite','redis','pydantic','pytest','ruff','mypy','httpx','requests','celery','psycopg','asyncpg','uvicorn','gunicorn'},
    'react-web': {'node','typescript','react','next','vite','tailwind','axios','tanstack-query','react-query','zustand','redux','redux-toolkit','react-router','zod','react-hook-form','jest','vitest','playwright','cypress','eslint','prettier'},
    'node-backend': {'node','typescript','express','fastify','nestjs','prisma','drizzle','postgres','sqlite','redis','axios','zod','jest','vitest','playwright','eslint','prettier'},
}

# Tecnologias que devem influenciar criação de kit. Dependências auxiliares ficam fora.
CORE_TECH = {'flutter','dart','python','fastapi','django','flask','node','typescript','react','next','vite','express','fastify','nestjs','go','ruby','rails','rust','dotnet','java'}
LIBRARY_TAGS = {'dio','http','graphql_flutter','riverpod','flutter_riverpod','hooks_riverpod','provider','flutter_bloc','bloc','getx','mobx','go_router','auto_route','freezed','json_serializable','build_runner','drift','sqflite','isar','hive','firebase','firebase_auth','cloud_firestore','flutter_test','mocktail','mockito','integration_test','sqlalchemy','alembic','pydantic','pytest','ruff','mypy','httpx','requests','celery','psycopg','asyncpg','uvicorn','gunicorn','prisma','drizzle','axios','tanstack-query','react-query','zustand','redux','redux-toolkit','react-router','zod','react-hook-form','jest','vitest','playwright','cypress','eslint','prettier','sidekiq','devise','graphql','rspec','rubocop','faraday','gin','chi','fiber','pgx','gorm','goose','sqlc'}
# Bibliotecas que alteram arquitetura/processo. Se o kit escolhido não cobrir, geram kit específico.
STRUCTURAL_LIBS = {'dio','graphql_flutter','riverpod','flutter_riverpod','hooks_riverpod','provider','flutter_bloc','bloc','getx','mobx','go_router','auto_route','drift','sqflite','isar','hive','firebase','firebase_auth','cloud_firestore','sqlalchemy','alembic','django','flask','celery','prisma','drizzle','tanstack-query','react-query','zustand','redux','redux-toolkit','react-router','zod','react-hook-form','rails','sidekiq','devise','graphql','gin','chi','fiber','pgx','gorm','goose','sqlc'}

def coverage_for_kit(kname: str) -> set[str]:
    if kname in KIT_COVERAGE:
        return set(KIT_COVERAGE[kname])
    mf=KITS/kname/'manifest.yaml'
    txt=read_text_if_exists(mf)
    tags=set()
    in_tags=False
    for raw in txt.splitlines():
        line=raw.strip()
        if line.startswith('tech_tags:') or line.startswith('library_tags:'):
            in_tags=True; continue
        if line.endswith(':') and not line.startswith('- '):
            in_tags=False; continue
        if in_tags and line.startswith('- '):
            tags.add(line[2:].strip().strip('"\''))
    return tags

def suggested_kit_name(tech: set[str]) -> str:
    priority=['flutter','rails','ruby','go','python','fastapi','django','flask','react','next','node','express','fastify','nestjs','rust','dotnet','java']
    chosen=[x for x in priority if x in tech]
    if not chosen:
        chosen=sorted(t for t in tech if t in CORE_TECH)[:3] or ['custom']
    # Evita criar node-react quando react-web já é suficiente; só chega aqui quando falta algo.
    return slug('-'.join(chosen[:4]) + '-kit')

def stack_description(target: Path, tech: set[str], signals: list[str]) -> str:
    name=target.name
    core=sorted(x for x in tech if x in CORE_TECH)
    libs=sorted(x for x in tech if x in LIBRARY_TAGS and x not in CORE_TECH)
    parts=[f"Tecnologias centrais: {', '.join(core) or 'desconhecidas'}"]
    if libs:
        parts.append(f"Bibliotecas estruturais/de fluxo: {', '.join(libs)}")
    parts.append(f"Sinais: {', '.join(signals[:12])}")
    return f"Kit específico para projeto existente `{name}`. " + '. '.join(parts) + '.'

def select_kit_name(target: Path, create_missing: bool=False) -> tuple[str, set[str], set[str], list[str], bool]:
    tech, signals = project_tech(target)
    ranked=[]
    for k in list_kits():
        s, sig = score_kit(k, target)
        covered=coverage_for_kit(k)
        important={x for x in tech if x in CORE_TECH or x in STRUCTURAL_LIBS}
        core={x for x in tech if x in CORE_TECH}
        missing=important - covered
        # Penaliza kit que acerta um pedaço mas deixa stack/biblioteca estrutural fora.
        penalty=len(missing)*25
        ranked.append((s-penalty, s, k, sig, missing, covered))
    ranked.sort(reverse=True)
    best=ranked[0] if ranked else (0,0,None,[],set(),set())
    important={x for x in tech if x in CORE_TECH or x in STRUCTURAL_LIBS}
    core={x for x in tech if x in CORE_TECH}
    if not important and (not best[2] or best[1] == 0):
        missing={'custom'}
    elif not best[2] or best[1] == 0:
        missing=important
    else:
        missing=important - best[5]
    if missing:
        new_name=suggested_kit_name(tech)
        if create_missing:
            desc=stack_description(target, tech, signals)
            if not (KITS/new_name).exists():
                create(argparse.Namespace(name=new_name, from_desc=desc, description=None, force=False))
                mf=KITS/new_name/'manifest.yaml'
                txt=read_text_if_exists(mf)
                if 'tech_tags:' not in txt:
                    tech_tags=sorted(x for x in tech if x in CORE_TECH)
                    lib_tags=sorted(x for x in tech if x in LIBRARY_TAGS and x not in CORE_TECH)
                    txt += 'tech_tags:\n' + ''.join(f'  - {x}\n' for x in tech_tags)
                    if lib_tags:
                        txt += 'library_tags:\n' + ''.join(f'  - {x}\n' for x in lib_tags)
                    mf.write_text(txt, encoding='utf-8')
            return new_name, tech, set(), signals, True
        return new_name, tech, missing, signals, False
    return best[2], tech, set(), signals, False

def analyze(args):
    target=Path(args.target).resolve()
    tech, signals=project_tech(target)
    kit, _tech, missing, _signals, created=select_kit_name(target, create_missing=False)
    result={'target': str(target), 'tech': sorted(x for x in tech if x in CORE_TECH), 'libraries': sorted(x for x in tech if x in LIBRARY_TAGS and x not in CORE_TECH), 'signals': signals, 'suggested_kit': kit, 'missing_core_tech': sorted(x for x in missing if x in CORE_TECH), 'missing_libraries': sorted(x for x in missing if x in STRUCTURAL_LIBS and x not in CORE_TECH), 'coverage_ok': not bool(missing)}
    if args.json:
        print(json.dumps(result, indent=2, ensure_ascii=False))
    else:
        print(f'Target: {target}')
        print('Detected tech: ' + (', '.join(sorted(x for x in tech if x in CORE_TECH)) or 'none'))
        libs=sorted(x for x in tech if x in LIBRARY_TAGS and x not in CORE_TECH)
        print('Detected libraries: ' + (', '.join(libs) or 'none'))
        print('Signals:')
        for s in signals: print(f'- {s}')
        print(f'Suggested kit: {kit}')
        print('Coverage: OK' if not missing else 'Coverage: MISSING ' + ', '.join(sorted(missing)))

def select(args):
    target=Path(args.target).resolve()
    if args.print_kit:
        import contextlib
        with contextlib.redirect_stdout(sys.stderr):
            kit, tech, missing, signals, created=select_kit_name(target, create_missing=args.create_missing)
        print(kit)
        return
    kit, tech, missing, signals, created=select_kit_name(target, create_missing=args.create_missing)
    print(f'Selected kit: {kit}')
    print('Detected tech: ' + (', '.join(sorted(x for x in tech if x in CORE_TECH)) or 'none'))
    libs=sorted(x for x in tech if x in LIBRARY_TAGS and x not in CORE_TECH)
    print('Detected libraries: ' + (', '.join(libs) or 'none'))
    if created: print('Created missing kit: yes')
    elif missing:
        print('Coverage missing: ' + ', '.join(sorted(missing)))
        print(f'Run: {Path(sys.argv[0]).name} select {target} --create-missing')
    else:
        print('Coverage: OK')

def score_kit(kname: str, target: Path) -> tuple[int, list[str]]:
    signals=[]; score=0
    if kname == 'flutter-app':
        if (target/'pubspec.yaml').exists(): score+=50; signals.append('pubspec.yaml found')
        txt=(target/'pubspec.yaml').read_text(errors='ignore') if (target/'pubspec.yaml').exists() else ''
        if 'flutter:' in txt: score+=40; signals.append('flutter: in pubspec.yaml')
    elif kname == 'python-backend':
        for f in ['pyproject.toml','requirements.txt','setup.py']:
            if (target/f).exists(): score+=30; signals.append(f'{f} found')
        for f in ['alembic.ini','app/main.py','src']:
            if (target/f).exists(): score+=10; signals.append(f'{f} found')
    elif kname == 'react-web':
        pkg=target/'package.json'
        if pkg.exists(): score+=30; signals.append('package.json found')
        txt=pkg.read_text(errors='ignore') if pkg.exists() else ''
        if 'react' in txt.lower(): score+=50; signals.append('react dependency/string found')
        if any((target/f).exists() for f in ['vite.config.ts','vite.config.js','next.config.js','next.config.mjs']): score+=10; signals.append('web framework config found')
    else:
        # generic generated backend/service/frontend hints
        if (target/'go.mod').exists() and 'go' in kname: score+=80; signals.append('go.mod found')
        if (target/'package.json').exists() and any(x in kname for x in ['node','web','frontend']): score+=50; signals.append('package.json found')
    return score, signals

def detect(args):
    target=Path(args.target).resolve()
    if not target.exists(): die(f'target inexistente: {target}')
    ranked=[]
    for k in list_kits():
        s, sig = score_kit(k, target)
        ranked.append((s,k,sig))
    ranked.sort(reverse=True)
    best=ranked[0] if ranked else (0,None,[])
    if not best[1] or best[0] == 0:
        die('não consegui detectar kit automaticamente')
    conf='high' if best[0] >= 70 else 'medium' if best[0] >= 40 else 'low'
    print(f'Detected kit: {best[1]}')
    print(f'Confidence: {conf}')
    print('\nSignals:')
    for s in best[2]: print(f'- {s}')
    return best[1]

def iter_files(base: Path):
    for p in sorted(base.rglob('*')):
        if p.is_file() and '.git' not in p.parts:
            yield p

def classify(kname: str, target: Path):
    kp=kit_path(kname)
    creates=[]; skips=[]; conflicts=[]
    for src in iter_files(kp):
        rel=src.relative_to(kp)
        dst=target/rel
        if not dst.exists(): creates.append(rel)
        elif dst.is_file() and sha(src)==sha(dst): skips.append(rel)
        else: conflicts.append(rel)
    return creates, skips, conflicts

def diff(args):
    target=Path(args.target).resolve()
    kname=args.kit
    if kname=='auto':
        ns=argparse.Namespace(target=str(target)); kname=detect(ns); print()
    creates,skips,conflicts=classify(kname,target)
    print(f'Kit: {kname}')
    print(f'Target: {target}\n')
    print('Would create:')
    for p in creates: print(f'  {p}')
    print('\nWould skip identical:')
    for p in skips: print(f'  {p}')
    print('\nWould conflict:')
    for p in conflicts: print(f'  {p} -> {p}.kit-new')
    print('\nNo files will be overwritten.' if not args.force else '\n--force enabled: conflicts would be overwritten.')

def git_commit() -> str:
    try:
        return subprocess.check_output(['git','rev-parse','HEAD'], cwd=ROOT, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return 'unknown'

def refresh(args):
    if (ROOT/'.git').exists():
        p=subprocess.run(['git','pull','--ff-only'], cwd=ROOT, text=True, capture_output=True)
        status='OK' if p.returncode==0 else 'WARN'
        print(f'git pull: {status}')
        if p.stdout.strip(): print(p.stdout.strip())
        if p.stderr.strip(): print(p.stderr.strip(), file=sys.stderr)
    validate(argparse.Namespace(kit=args.kit))
    reports=ROOT/'.refresh-reports'; reports.mkdir(exist_ok=True)
    report=reports/f'{args.kit}-{dt.datetime.utcnow().strftime("%Y%m%dT%H%M%SZ")}.md'
    report.write_text(f'# Refresh report: {args.kit}\n\n- generated_at: {dt.datetime.utcnow().isoformat()}Z\n- structure: checked\n- semantic refresh: manual review required\n', encoding='utf-8')
    print(f'Refresh report: {report}')

def detect_project_name(target: Path) -> str:
    """Detecta o nome do projeto alvo para substituição de {{PROJECT_NAME}}."""
    # 1. package.json "name"
    pkg_path = target / 'package.json'
    if pkg_path.exists():
        try:
            pkg = json.loads(pkg_path.read_text(encoding='utf-8'))
            name = pkg.get('name', '').strip()
            if name:
                return name
        except Exception:
            pass
    # 2. pubspec.yaml "name:"
    pubspec = target / 'pubspec.yaml'
    if pubspec.exists():
        for line in pubspec.read_text(encoding='utf-8', errors='ignore').splitlines():
            if line.startswith('name:'):
                name = line.split(':', 1)[1].strip().strip('"\'')
                if name:
                    return name
                break
    # 3. pyproject.toml [project] name =
    pyproject = target / 'pyproject.toml'
    if pyproject.exists():
        for line in pyproject.read_text(encoding='utf-8', errors='ignore').splitlines():
            stripped = line.strip()
            if stripped.startswith('name'):
                name = stripped.split('=', 1)[1].strip().strip('"\'') if '=' in stripped else ''
                if name:
                    return name
                break
    # 4. Fallback: nome do diretório
    return target.name

def apply(args):
    target=Path(args.target).resolve(); target.mkdir(parents=True, exist_ok=True)
    kname=args.kit
    if kname=='auto':
        kname=detect(argparse.Namespace(target=str(target))); print()
    if args.refresh:
        refresh(argparse.Namespace(kit=kname))
    # Resolve project name para substituição de placeholders
    project_name = getattr(args, 'project_name', None) or detect_project_name(target)
    kp=kit_path(kname)
    created=[]; skipped=[]; conflicted=[]; overwritten=[]
    for src in iter_files(kp):
        rel=src.relative_to(kp); dst=target/rel
        dst.parent.mkdir(parents=True, exist_ok=True)
        # Não sobrescrever DESIGN_SYSTEM.md se já tem conteúdo real (da design phase)
        if rel == Path('docs/ai/DESIGN_SYSTEM.md') and dst.exists():
            existing = read_text_if_exists(dst)
            if existing and len(existing) > 200 and 'Gerado automaticamente' not in existing and 'Fonte:' not in existing.split('\n')[0:5]:
                skipped.append(str(rel))
                continue
        if not dst.exists():
            content = src.read_text(encoding='utf-8', errors='ignore') if src.suffix in ('.md', '.yaml', '.yml', '.txt', '.json', '.toml') else None
            if content and '{{PROJECT_NAME}}' in content:
                content = content.replace('{{PROJECT_NAME}}', project_name)
                dst.write_text(content, encoding='utf-8')
            else:
                shutil.copy2(src, dst)
            created.append(str(rel))
        elif dst.is_file() and sha(src)==sha(dst):
            skipped.append(str(rel))
        elif args.force:
            # force: aplica substituição também ao sobrescrever
            content = src.read_text(encoding='utf-8', errors='ignore') if src.suffix in ('.md', '.yaml', '.yml', '.txt', '.json', '.toml') else None
            if content and '{{PROJECT_NAME}}' in content:
                content = content.replace('{{PROJECT_NAME}}', project_name)
                dst.write_text(content, encoding='utf-8')
            else:
                shutil.copy2(src, dst)
            overwritten.append(str(rel))
        else:
            # conflito: aplica substituição no .kit-new
            content = src.read_text(encoding='utf-8', errors='ignore') if src.suffix in ('.md', '.yaml', '.yml', '.txt', '.json', '.toml') else None
            ndst=Path(str(dst)+'.kit-new')
            i=1
            while ndst.exists():
                ndst=Path(str(dst)+f'.kit-new.{i}'); i+=1
            if content and '{{PROJECT_NAME}}' in content:
                content = content.replace('{{PROJECT_NAME}}', project_name)
                ndst.write_text(content, encoding='utf-8')
            else:
                shutil.copy2(src, ndst)
            conflicted.append(f'{rel} -> {ndst.relative_to(target)}')
    lock=target/LOCKFILE
    lock.write_text('\n'.join([
        f'kit: {kname}',
        'kit_version: 1',
        f'applied_at: "{dt.datetime.utcnow().isoformat()}Z"',
        'source_repo: "github.com/marcelsanches2/bootstrap-ai"',
        f'source_commit: "{git_commit()}"',
        f'project_name: "{project_name}"',
        f'conflict_policy: {"force-overwrite" if args.force else "keep-existing-create-new"}',
        ''
    ]), encoding='utf-8')
    print(f'Applied kit: {kname}')
    print(f'Project name: {project_name}')
    print(f'Created: {len(created)} | Skipped: {len(skipped)} | Conflicts: {len(conflicted)} | Overwritten: {len(overwritten)}')
    if conflicted:
        print('\nConflicts:')
        for x in conflicted: print(f'- {x}')
    print(f'Lockfile: {lock}')

def validate(args):
    kp=kit_path(args.kit)
    missing=[];warnings=[]
    req=list(REQUIRED_COMMON)
    mf=kp/'manifest.yaml'
    if mf.exists():
        txt=mf.read_text(encoding='utf-8')
        for line in txt.splitlines():
            line=line.strip()
            if line.startswith('- '):
                val=line[2:].strip().strip('"\'' )
                if '/' in val or val.endswith('.md'):
                    req.append(val)
    for rel in sorted(set(req)):
        if not (kp/rel).exists(): missing.append(rel)
    # check jarvis references to product_roles
    jr=kp/'.claude/commands/jarvis-plan-revisor.md'
    if jr.exists():
        txt=jr.read_text(errors='ignore')
        import re
        for m in re.findall(r'product_roles/[\w\-]+\.md', txt):
            if not (kp/'.claude/commands'/m).exists(): missing.append('.claude/commands/'+m)
    # quality checks: no TODO, no stub content, minimum line counts
    import re as _re
    for f in sorted(kp.rglob('*.md')):
        if '.git' in str(f): continue
        rel_f=str(f.relative_to(kp))
        content=f.read_text(encoding='utf-8',errors='ignore')
        lines=[l for l in content.splitlines() if l.strip()]
        if 'TODO' in content: warnings.append(f'{rel_f}: contains TODO')
        if len(lines)<5: warnings.append(f'{rel_f}: too short ({len(lines)} non-empty lines, min 5)')
        # specific minimums
        if f.name=='CLAUDE.md' and len(lines)<40: warnings.append(f'{rel_f}: CLAUDE.md too short ({len(lines)} lines, min 40)')
        if 'product_roles' in str(f) and len(lines)<15: warnings.append(f'{rel_f}: role/review too short ({len(lines)} lines, min 15)')
        if f.parent.name=='ai' and len(lines)<30: warnings.append(f'{rel_f}: doc too short ({len(lines)} lines, min 30)')
        if f.name.startswith('jarvis-test-flow') and len(lines)<50: warnings.append(f'{rel_f}: test flow too short ({len(lines)} lines, min 50)')
        if f.name.startswith('jarvis-plan-revisor') and len(lines)<30: warnings.append(f'{rel_f}: revisor too short ({len(lines)} lines, min 30)')
    # naming convention checks
    for f in sorted((kp/'.claude/commands/product_roles').glob('*.md')):
        # helpers (carregar-*, consolidar-*, gerar-*, localizar-*) are not roles/reviews
        if any(f.name.startswith(p) for p in ['carregar-','consolidar-','gerar-','localizar-']): continue
        if f.name.startswith('role-') or f.name.startswith('review-'): continue
        warnings.append(f'product_roles/{f.name}: must start with role- or review-')
    for f in sorted((kp/'docs/ai').glob('*.md')):
        import re as _re2
        if not _re2.match(r'^[A-Z][A-Z0-9_]*\.md$', f.name):
            warnings.append(f'docs/ai/{f.name}: must be UPPER_SNAKE_CASE')
    # separation of concerns: testing content outside TESTING_GUIDE
    testing_terms=['jest','pytest','flutter test','vitest','test framework','cobertura','coverage']
    for f in sorted((kp/'docs/ai').glob('*.md')):
        if f.name=='TESTING_GUIDE.md': continue
        content=f.read_text(encoding='utf-8',errors='ignore').lower()
        found=[t for t in testing_terms if t in content]
        if len(found)>3: warnings.append(f'docs/ai/{f.name}: testing content belongs in TESTING_GUIDE (found: {found})')
    if missing:
        print(f'Kit {args.kit}: FAIL')
        for m in sorted(set(missing)): print(f'- missing {m}')
        for w in warnings: print(f'- warning: {w}')
        raise SystemExit(1)
    if warnings:
        print(f'Kit {args.kit}: OK (with warnings)')
        for w in warnings: print(f'- warning: {w}')
    else:
        print(f'Kit {args.kit}: OK')

def slug(s: str) -> str:
    import re
    s=s.lower().strip().replace('_','-')
    return re.sub(r'[^a-z0-9-]+','-',s).strip('-')

def create(args):
    name=slug(args.name)
    desc=args.from_desc or args.description or name
    kp=KITS/name
    if kp.exists() and not args.force: die(f'preset já existe: {name}')
    # Create directory structure only — content is generated by the LLM via generator prompt
    kp.mkdir(parents=True, exist_ok=True)
    (kp/'.claude/commands/product_roles').mkdir(parents=True, exist_ok=True)
    (kp/'docs/ai').mkdir(parents=True, exist_ok=True)
    (kp/'plans').mkdir(exist_ok=True)
    (kp/'plans/.gitkeep').write_text('', encoding='utf-8')
    (kp/'.claude/settings.json').parent.mkdir(parents=True, exist_ok=True)
    print(f'Created preset structure: {name}')
    print(f'Stack: {desc}')
    print(f'')
    print(f'Next step: generate content using the creator prompt.')
    print(f'  1. Read: generators/skill-creator/prompts/create-new-preset.md')
    print(f'  2. Use derive prompts for each component:')
    print(f'     - generators/skill-creator/prompts/derive-roles.md')
    print(f'     - generators/skill-creator/prompts/derive-docs-ai.md')
    print(f'     - generators/skill-creator/prompts/derive-test-flow.md')
    print(f'  3. Read the most similar existing preset as reference')
    print(f'  4. Generate ALL files with stack-specific content (not stubs)')
    print(f'  5. Validate: bin/bootstrap-ai validate {name}')

def install_importer(args):
    target=Path(args.target).resolve()
    target.mkdir(parents=True, exist_ok=True)
    src=ROOT/'bootstrap/import-project-preset.md'
    if not src.exists(): die('bootstrap/import-project-preset.md não encontrado')
    dst=target/'.claude/commands/import-project-preset.md'
    dst.parent.mkdir(parents=True, exist_ok=True)
    # Lê template e injeta path absoluto da origem
    content=src.read_text(encoding='utf-8')
    source_marker=f'\n<!-- BOOTSTRAP_AI_SOURCE: {ROOT} -->\n'
    # Remove marker antigo se existir
    import re
    content=re.sub(r'\n*<!-- BOOTSTRAP_AI_SOURCE:.*?-->\n*', '\n', content).rstrip()
    content+=source_marker
    if dst.exists() and not args.force:
        existing=dst.read_text(encoding='utf-8')
        # Compara ignorando o marker (que muda por máquina)
        clean_existing=re.sub(r'\n*<!-- BOOTSTRAP_AI_SOURCE:.*?-->\n*', '\n', existing).rstrip()
        clean_src=re.sub(r'\n*<!-- BOOTSTRAP_AI_SOURCE:.*?-->\n*', '\n', content).rstrip()
        if clean_existing==clean_src and f'BOOTSTRAP_AI_SOURCE: {ROOT}' in existing:
            print(f'Importer já instalado: {dst}')
            return
        ndst=Path(str(dst)+'.kit-new')
        i=1
        while ndst.exists():
            ndst=Path(str(dst)+f'.kit-new.{i}'); i+=1
        dst.write_text(content, encoding='utf-8')
        print(f'Conflito: importer existente. Atualizado em {dst}')
        return
    dst.write_text(content, encoding='utf-8')
    print(f'Importer instalado: {dst}')
    print(f'Source embutido: {ROOT}')
    print('Use no Claude Code: /import-project-preset')

def main():
    p=argparse.ArgumentParser(prog='kit')
    sub=p.add_subparsers(dest='cmd', required=True)
    s=sub.add_parser('detect'); s.add_argument('target'); s.set_defaults(func=detect)
    s=sub.add_parser('analyze'); s.add_argument('target'); s.add_argument('--json', action='store_true'); s.set_defaults(func=analyze)
    s=sub.add_parser('select'); s.add_argument('target'); s.add_argument('--create-missing', action='store_true'); s.add_argument('--print-preset', action='store_true'); s.set_defaults(func=select)
    s=sub.add_parser('diff'); s.add_argument('kit'); s.add_argument('target'); s.add_argument('--force', action='store_true'); s.set_defaults(func=diff)
    s=sub.add_parser('apply'); s.add_argument('kit'); s.add_argument('target'); s.add_argument('--refresh', action='store_true'); s.add_argument('--force', action='store_true'); s.add_argument('--project-name', dest='project_name', default=None); s.set_defaults(func=apply)
    s=sub.add_parser('refresh'); s.add_argument('kit'); s.set_defaults(func=refresh)
    s=sub.add_parser('validate'); s.add_argument('kit'); s.set_defaults(func=validate)
    s=sub.add_parser('create'); s.add_argument('name'); s.add_argument('--from', dest='from_desc'); s.add_argument('--description'); s.add_argument('--force', action='store_true'); s.set_defaults(func=create)
    s=sub.add_parser('install-importer'); s.add_argument('target'); s.add_argument('--force', action='store_true'); s.set_defaults(func=install_importer)
    args=p.parse_args(); args.func(args)
if __name__ == '__main__': main()
